{
  "targetDefaults": {
    "build:deps": {
      "dependsOn": [
        "^update:deps"
      ],
      "outputs": [
        "{projectRoot}/koa*.js"
      ],
      "cache": true
    },
    "update:deps": {
      "dependsOn": [],
      "outputs": [],
      "cache": true
    },
    "doc:deps": {
      "dependsOn": [
        "^update:deps",
        "^build:deps"
      ],
      "outputs": [
        "{workspaceRoot}/README.md"
      ],
      "cache": true
    },
    "doc-internal-packages": {
      "dependsOn": [
        "^update:deps",
        "^build:deps"
      ],
      "outputs": [
        "{workspaceRoot}/README.md"
      ]
    },
    "build": {
      "dependsOn": [
        "^build:deps"
      ],
      "outputs": [
        "{projectRoot}/packages/**/build"
      ],
      "cache": true
    },
    "clean": {
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "cache": true
    }
  }
}
